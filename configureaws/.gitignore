# Terraform working directory
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan

# Terraform CLI config
.terraformrc
terraform.rc

# Sensitive environment files
.env
.env.*
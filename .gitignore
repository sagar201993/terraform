# Terraform working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Environment files
.env
.env.*
